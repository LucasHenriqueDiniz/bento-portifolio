# Discord Integration
# Used for: Discord presence card via Lanyard API and contact form notifications
DISCORD_ID=your_discord_user_id_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# MyAnimeList Integration
# Used for: Anime/Manga stats via Jikan API
MAL_USERNAME=your_mal_username_here

# Lyfta Integration
# Used for: Lyfta platform integration
LYFTA_API_KEY=your_lyfta_api_key_here

# Steam Integration
# Used for: Gaming profile, recent games, owned games
STEAM_API_KEY=your_steam_api_key_here
STEAM_ID=your_steam_id_here

# Last.fm Integration
# Used for: Music stats, recent tracks, top artists
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here

# GitHub Integration
# Used for: GitHub repositories and contributions
GITHUB_USERNAME=your_github_username_here
GITHUB_PAT=your_github_personal_access_token_here
